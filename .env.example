# Pulse — environment variables. Copy to `.env` and fill in.
#
# Sprint 3+: Skeptic and VLMReasoner now prefer local model inference
# (InternVL2-2B or LLaVA-1.6-7B). No API key needed for local mode.
# The external API is a fallback when local models aren't available.

# Optional: External LLM API key (fallback for Skeptic + VLMReasoner).
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the chat model for the external API path.
# PULSE_LLM_MODEL=gpt-4o-mini

# Optional: HuggingFace token for higher download rate limits / private models.
# HF_TOKEN=hf_...

# Optional: Weather Prior Agent location (default: California Central Valley).
# PULSE_LATITUDE=36.7
# PULSE_LONGITUDE=-119.8
