# Pesto — environment variables. Copy to `.env` and fill in.
#
# Skeptic and VLMReasoner prefer local model inference (InternVL2-2B or
# LLaVA-1.6-7B). No API key needed for local mode. The external API is a
# fallback when local models aren't available.

# Optional: External LLM API key (fallback for Skeptic + VLMReasoner).
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the chat model for the external API path.
# PESTO_LLM_MODEL=gpt-4o-mini

# Optional: HuggingFace token for higher download rate limits / private models.
# HF_TOKEN=hf_...

# Optional: Weather Prior Agent location (default: California Central Valley).
# PESTO_LATITUDE=36.7
# PESTO_LONGITUDE=-119.8
