# Pulse — environment variables. Copy to `.env` and fill in.
# Only OPENAI_API_KEY is required for the LLM-backed agents
# (Skeptic + VLMReasoner). Without it, the rest of the pipeline still runs.

OPENAI_API_KEY=sk-...

# Optional: override the chat model (default: gpt-4o-mini).
# PULSE_LLM_MODEL=gpt-4o-mini

# Optional: HuggingFace token for higher download rate limits / private models.
# HF_TOKEN=hf_...
